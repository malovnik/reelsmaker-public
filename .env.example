# LLM providers
# Primary: Gemini 2.5 Flash (default pipeline model)
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# Optional: Claude (pass-3 alternative, has prompt caching)
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-5-20250929

# Optional: OpenAI (GPT alternative)
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-5

# Optional: Zhipu Z.AI (GLM-5.1, OpenAI-compatible)
# Ключ формата <id>.<secret> из https://open.bigmodel.cn/usercenter/apikeys
#
# ZHIPU_BASE_URL зависит от плана:
# - Coding Plan подписка ($18/мес, рекомендовано для pipeline):
#     https://api.z.ai/api/coding/paas/v4  (дефолт)
#     Модели: glm-5.1, glm-5-turbo, glm-4.7, glm-4.5-air
# - General pay-as-you-go API:
#     https://open.bigmodel.cn/api/paas/v4
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZHIPU_DEFAULT_MODEL=glm-5.1
ZHIPU_PRO_MODEL=glm-5.1
ZHIPU_FLASH_MODEL=glm-5.1
ZHIPU_FLASH_LITE_MODEL=glm-5.1
ZHIPU_MAX_OUTPUT_TOKENS=16000

# Speech-to-text providers
# Primary: local mlx-whisper (no key needed)
MLX_WHISPER_MODEL=mlx-community/whisper-large-v3-turbo

# Optional: Deepgram (nova-3 with word-level timestamps)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# Image generation (B-roll, v1+)
# Uses GEMINI_API_KEY above with model gemini-2.5-flash-image-preview

# Application settings
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_DB_PATH=./data/videomaker.db
APP_ARTIFACTS_DIR=./data/artifacts
APP_UPLOAD_DIR=./data/uploads
APP_MAX_UPLOAD_SIZE_MB=30720

# Frontend URL for CORS
FRONTEND_ORIGIN=http://localhost:3000

# Public backend origin (no trailing slash) — база для OAuth redirect_uri
# когда YOUTUBE_REDIRECT_URI / INSTAGRAM_REDIRECT_URI не заданы явно.
# В production поменять на https://api.yourdomain.com
PUBLIC_BACKEND_ORIGIN=http://localhost:8000

# OAuth callbacks (опционально — если пусто, derive from PUBLIC_BACKEND_ORIGIN)
# YOUTUBE_REDIRECT_URI=
# INSTAGRAM_REDIRECT_URI=

# Chunking thresholds (see plan "Chunking strategy")
CHUNK_TOKEN_THRESHOLD=20000
CHUNK_WINDOW_TOKENS=15000
CHUNK_OVERLAP_TOKENS=1500
LLM_MAX_CONCURRENCY=10
