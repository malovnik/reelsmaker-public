@echo off
rem ============================================================================
rem  Reelibra — точка входа для Windows. Двойной клик по этому файлу.
rem
rem  Это тонкая обёртка: единственная её задача — запустить PowerShell-лаунчер
rem  с обходом ExecutionPolicy. Вся логика (bootstrap раннеров, диагностика,
rem  уборка, запуск серверов) живёт в launchers\windows\launcher.ps1.
rem
rem  Почему .cmd, а не .exe или .ps1:
rem    - .exe провоцирует SmartScreen/антивирус («неизвестный издатель»);
rem    - двойной клик по .ps1 открывает редактор, а не запускает скрипт;
rem    - голый .cmd запускается двойным кликом и не требует подписи.
rem ============================================================================

rem UTF-8 в консоли — чтобы русские сообщения и пути с кириллицей не ломались.
chcp 65001 >nul 2>&1

rem %~dp0 — папка этого .cmd (с обратным слэшем на конце), корректно работает
rem с пробелами и кириллицей в пути. Кавычки обязательны.
set "REELIBRA_ROOT=%~dp0"

powershell -NoProfile -ExecutionPolicy Bypass -File "%REELIBRA_ROOT%launchers\windows\launcher.ps1"
set "EXITCODE=%ERRORLEVEL%"

rem Если PowerShell-лаунчер сам не задержал окно (например, упал до своего
rem финального паузатора) — даём пользователю прочитать сообщение об ошибке.
if not "%EXITCODE%"=="0" (
    echo.
    echo Reelibra завершился с ошибкой. Окно останется открытым.
    pause >nul
)

exit /b %EXITCODE%
